# Public backend
NODE_ENV=development
EXIT_ON_UNHANDLED=false
STARTUP_DEBUG=false
PORT=3000
BASE_URL=http://localhost
ORIGIN=http://localhost:4200
TRUST_PROXY=loopback, linklocal, uniquelocal
# PostgreSQL backpressure: BACKEND_DB_POOL_MAX controls parallel DB connections.
# DB_MAX_PENDING_REQUESTS limits total active/waiting DB tasks before returning 503 database_busy.
DB_MAX_PENDING_REQUESTS=1000
DB_OVERLOAD_RETRY_AFTER_SECONDS=2
PUBLIC_MESSAGE_SEARCH_CACHE_TTL_MS=10000
PUBLIC_MESSAGE_SEARCH_CACHE_MAX=500

# Admin log forwarding
ADMIN_BASE_URL=http://localhost
ADMIN_PORT=3100
ADMIN_LOG_URL=
SERVICE_JWT_AUDIENCE_ADMIN=service.admin-backend
FORWARD_BACKEND_LOGS=true
LOG_FORWARD_MAX_QUEUE=200
LOG_FORWARD_CONCURRENCY=2

# Service JWT
SERVICE_JWT_ISSUER=service.backend
SERVICE_JWT_AUDIENCE=service.backend
SERVICE_JWT_TRUSTED_JWKS=
SERVICE_JWT_TRUSTED_JWKS_PATH=

# Encryption keys
ENCRYPTION_KEY_PASSWORD=change_me
SIGNING_KEY_PASSWORD=change_me

# Auth/secrets
JWT_SECRET=change_me
PIN_SALT=change_me

# Proof of Work
POW_SECRET=change_me
POW_TTL_MS=120000
POW_DIFFICULTY=12
POW_EVIDENCE_DIFFICULTY=12
POW_MAX_DIFFICULTY=20
POW_WINDOW_MS=300000
POW_THRESHOLD=20
POW_SUSPICIOUS_THRESHOLD=10
POW_REQUIRE_TTL_MS=600000

# DSA
DSA_EVIDENCE_MAX_FILE_MB=1
DSA_REPORTS_PER_IP_PER_HOUR=1

# External APIs
OPENAI_API_KEY_MODERATION=change_me
DEEPL_API_KEY=change_me
TENOR_API_KEY=change_me
TENOR_CLIENT_KEY=messagedrop
TENOR_BASE_URL=https://tenor.googleapis.com/v2
KLIPY_API_KEY=change_me
KLIPY_CLIENT_KEY=messagedrop
KLIPY_BASE_URL=https://api.klipy.com
KLIPY_API_TIMEOUT_MS=5000
KLIPY_PER_PAGE=30
KLIPY_CONTENT_FILTER=low
KLIPY_FORMAT_FILTER=gif,webp,jpg,mp4,webm
UNSPLASH_ACCESS_KEY=change_me
UNSPLASH_SECRET_KEY=change_me
UNSPLASH_BASE_URL=https://api.unsplash.com

# Service endpoints
OPENMETEO_BASE_URL=http://localhost
OPENMETEO_PORT=3200
OPENMETEO_PROXY_TIMEOUT_MS=12000
GEOSTATISTIC_EXTERNAL_TIMEOUT_MS=5000
SERVICE_JWT_AUDIENCE_OPENMETEO=service.openmeteo
NOMINATIM_BASE_URL=http://localhost
NOMINATIM_PORT=3300
SERVICE_JWT_AUDIENCE_NOMINATIM=service.nominatim
VIATOR_BASE_URL=http://localhost
VIATOR_PORT=3500
SERVICE_JWT_AUDIENCE_VIATOR=service.viator
STICKER_BASE_URL=http://localhost
STICKER_PORT=3600
SERVICE_JWT_AUDIENCE_STICKER=service.sticker
STICKER_PROXY_TIMEOUT_MS=15000
VIATOR_PROXY_TIMEOUT_MS=20000
SOCKETIO_BASE_URL=http://localhost
SOCKETIO_PORT=3400
SERVICE_JWT_AUDIENCE_SOCKET=service.socketio

# Logging
LOG_RETENTION_INFO=2d
LOG_RETENTION_ERROR=2d
SLOW_REQUEST_LOG_ENABLED=true
SLOW_REQUEST_THRESHOLD_MS=1000
SLOW_REQUEST_LOG_MAX_PER_MINUTE=60

# PostgreSQL database (Public backend)
# Prefer BACKEND_DATABASE_URL when available. Otherwise BACKEND_DB_* is used.
BACKEND_DATABASE_URL=
BACKEND_DB_HOST=localhost
BACKEND_DB_PORT=5432
BACKEND_DB_NAME=messagedrop_backend
BACKEND_DB_USER=messagedrop
BACKEND_DB_PASSWORD=messagedrop_dev_password
BACKEND_DB_SSL=false
BACKEND_DB_POOL_MAX=10
