# OpenMeteo service
NODE_ENV=development
EXIT_ON_UNHANDLED=false
OPENMETEO_PORT=3200
OPENMETEO_UPSTREAM_TIMEOUT_MS=10000

# Admin log forwarding
ADMIN_BASE_URL=http://localhost
ADMIN_PORT=3100
ADMIN_LOG_URL=
SERVICE_JWT_AUDIENCE_ADMIN=service.admin-backend

# Service JWT
SERVICE_JWT_ISSUER=service.openmeteo
SERVICE_JWT_AUDIENCE=service.openmeteo
SERVICE_JWT_TRUSTED_JWKS=
SERVICE_JWT_TRUSTED_JWKS_PATH=

# Encryption keys
ENCRYPTION_KEY_PASSWORD=change_me
SIGNING_KEY_PASSWORD=change_me

# Logging
LOG_RETENTION_INFO=2d
LOG_RETENTION_ERROR=2d

# PostgreSQL database (OpenMeteo service)
# Prefer OPENMETEO_DATABASE_URL when available. Otherwise OPENMETEO_DB_* is used.
OPENMETEO_DATABASE_URL=
OPENMETEO_DB_HOST=localhost
OPENMETEO_DB_PORT=5432
OPENMETEO_DB_NAME=messagedrop_openmeteo
OPENMETEO_DB_USER=messagedrop
OPENMETEO_DB_PASSWORD=messagedrop_dev_password
OPENMETEO_DB_SSL=false
OPENMETEO_DB_POOL_MAX=10
