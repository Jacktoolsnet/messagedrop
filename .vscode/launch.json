{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Start PostgreSQL",
            "type": "node-terminal",
            "request": "launch",
            "command": "sudo service postgresql start && pg_isready",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Admin-Service",
            "program": "${workspaceFolder}/platform/admin/backend/app.js",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "SERVICE_JWT_ISSUER": "service.admin-backend",
                "SERVICE_JWT_AUDIENCE": "service.admin-backend",
                "SERVICE_JWT_TRUSTED_JWKS_PATH": "${workspaceFolder}/platform/admin/backend/config/service-jwks.json"
            },
            "type": "node"
        },
        {
            "name": "Messagedrop-Service",
            "program": "${workspaceFolder}/backend/app.js",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "SERVICE_JWT_ISSUER": "service.backend",
                "SERVICE_JWT_AUDIENCE": "service.backend",
                "SERVICE_JWT_TRUSTED_JWKS_PATH": "${workspaceFolder}/backend/config/service-jwks.json"
            },
            "type": "node"
        },
        {
            "name": "OpenMeteo-Service",
            "program": "${workspaceFolder}/services/openMeteo/app.js",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "SERVICE_JWT_ISSUER": "service.openmeteo",
                "SERVICE_JWT_AUDIENCE": "service.openmeteo",
                "SERVICE_JWT_TRUSTED_JWKS_PATH": "${workspaceFolder}/services/openMeteo/config/service-jwks.json"
            },
            "type": "node"
        },
        {
            "name": "Nominatim-Service",
            "program": "${workspaceFolder}/services/nominatim/app.js",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "SERVICE_JWT_ISSUER": "service.nominatim",
                "SERVICE_JWT_AUDIENCE": "service.nominatim",
                "SERVICE_JWT_TRUSTED_JWKS_PATH": "${workspaceFolder}/services/nominatim/config/service-jwks.json"
            },
            "type": "node"
        },
        {
            "name": "SocketIO-Service",
            "program": "${workspaceFolder}/services/socketio/app.js",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "SERVICE_JWT_ISSUER": "service.socketio",
                "SERVICE_JWT_AUDIENCE": "service.socketio",
                "SERVICE_JWT_TRUSTED_JWKS_PATH": "${workspaceFolder}/services/socketio/config/service-jwks.json"
            },
            "type": "node"
        },
        {
            "name": "Viator-Service",
            "program": "${workspaceFolder}/services/viator/app.js",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "SERVICE_JWT_ISSUER": "service.viator",
                "SERVICE_JWT_AUDIENCE": "service.viator",
                "SERVICE_JWT_TRUSTED_JWKS_PATH": "${workspaceFolder}/services/viator/config/service-jwks.json"
            },
            "type": "node"
        },
        {
            "name": "Sticker-Service",
            "program": "${workspaceFolder}/services/sticker/app.js",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "SERVICE_JWT_ISSUER": "service.sticker",
                "SERVICE_JWT_AUDIENCE": "service.sticker",
                "SERVICE_JWT_TRUSTED_JWKS_PATH": "${workspaceFolder}/services/sticker/config/service-jwks.json"
            },
            "type": "node"
        },
        {
            "name": "Messagedrop-App",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/frontend",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "start"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "ADMIN-App",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/platform/admin/frontend",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "start"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Generate Service (T) JWKs",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/tools/generate-service-jwks.js",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Generate Service (Q) JWKs",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/tools/generate-stage-service-jwks.js",
            "console": "integratedTerminal",
            "args": [
                "--stage",
                "q"
            ],
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Generate Service (P) JWKs",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/tools/generate-stage-service-jwks.js",
            "console": "integratedTerminal",
            "args": [
                "--stage",
                "p"
            ],
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Build Frontend",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/frontend",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "build",
                "--",
                "--configuration",
                "production"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Build Messagedrop Static",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/platform/messagedrop",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "build"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Build AdminFrontend",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/platform/admin/frontend",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "build",
                "--",
                "--configuration",
                "production"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Security: Protected Route Smoke Tests",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/tools/security/protected-route-smoke.js",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Security: OWASP ZAP Baseline Backend",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/tools/security/run-zap-baseline.js",
            "args": [
                "--target",
                "http://127.0.0.1:3000",
                "--name",
                "backend"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Security: OWASP ZAP Baseline Admin",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/tools/security/run-zap-baseline.js",
            "args": [
                "--target",
                "http://127.0.0.1:3100",
                "--name",
                "admin-backend"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Security: OWASP ZAP Baseline All Local",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/tools/security/run-zap-baseline.js",
            "args": [
                "--all-local"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "DBeaver Messagedrop Backend",
            "type": "node-terminal",
            "request": "launch",
            "command": "node tools/db/open-dbeaver.js BACKEND",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "DBeaver Admin Backend",
            "type": "node-terminal",
            "request": "launch",
            "command": "node tools/db/open-dbeaver.js ADMIN",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "DBeaver Sticker Service",
            "type": "node-terminal",
            "request": "launch",
            "command": "node tools/db/open-dbeaver.js STICKER",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "DBeaver Viator Service",
            "type": "node-terminal",
            "request": "launch",
            "command": "node tools/db/open-dbeaver.js VIATOR",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "DBeaver OpenMeteo Service",
            "type": "node-terminal",
            "request": "launch",
            "command": "node tools/db/open-dbeaver.js OPENMETEO",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "DBeaver Nominatim Service",
            "type": "node-terminal",
            "request": "launch",
            "command": "node tools/db/open-dbeaver.js NOMINATIM",
            "cwd": "${workspaceFolder}"
        }
    ]
}