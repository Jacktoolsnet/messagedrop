# Nominatim service
NODE_ENV=development
EXIT_ON_UNHANDLED=false
STARTUP_DEBUG=false
NOMINATIM_PORT=3300
NOMINATIM_USER_AGENT=messagedrop.dev

# Admin log forwarding
ADMIN_BASE_URL=http://localhost
ADMIN_PORT=3100
ADMIN_LOG_URL=
SERVICE_JWT_AUDIENCE_ADMIN=service.admin-backend

# Service JWT
SERVICE_JWT_ISSUER=service.nominatim
SERVICE_JWT_AUDIENCE=service.nominatim
SERVICE_JWT_TRUSTED_JWKS=
SERVICE_JWT_TRUSTED_JWKS_PATH=

# Encryption keys
ENCRYPTION_KEY_PASSWORD=change_me
SIGNING_KEY_PASSWORD=change_me

# Logging
LOG_RETENTION_INFO=2d
LOG_RETENTION_ERROR=2d

# PostgreSQL database (Nominatim service)
# Prefer NOMINATIM_DATABASE_URL when available. Otherwise NOMINATIM_DB_* is used.
NOMINATIM_DATABASE_URL=
NOMINATIM_DB_HOST=localhost
NOMINATIM_DB_PORT=5432
NOMINATIM_DB_NAME=messagedrop_nominatim
NOMINATIM_DB_USER=messagedrop
NOMINATIM_DB_PASSWORD=messagedrop_dev_password
NOMINATIM_DB_SSL=false
# Nominatim PostgreSQL backpressure: NOMINATIM_DB_POOL_MAX controls parallel DB connections.
# NOMINATIM_DB_MAX_PENDING_REQUESTS limits total active/waiting Nominatim DB tasks before returning 503 database_busy.
NOMINATIM_DB_POOL_MAX=10
NOMINATIM_DB_MAX_PENDING_REQUESTS=1000
NOMINATIM_DB_OVERLOAD_RETRY_AFTER_SECONDS=2
