NODE_ENV=development
WIKIPEDIA_PORT=3700
WIKIPEDIA_USER_AGENT=MessageDrop-WikipediaBot/1.0 (https://messagedrop.de/; support@messagedrop.de)
WIKIPEDIA_UPSTREAM_TIMEOUT_MS=10000
WIKIPEDIA_REQUEST_INTERVAL_MS=150
WIKIPEDIA_TILE_RESULT_LIMIT=20
WIKIPEDIA_MAX_RESULTS_PER_TILE=500
WIKIPEDIA_MAX_PENDING_UPSTREAM_JOBS=100
WIKIPEDIA_THUMBNAIL_SIZE=240
WIKIPEDIA_EXTRACT_CHARS=280
WIKIPEDIA_MIN_ZOOM=14
WIKIPEDIA_CACHE_TILE_ZOOM=14
WIKIPEDIA_MAX_TILES_PER_REQUEST=64
WIKIPEDIA_CACHE_FRESH_MS=86400000
WIKIPEDIA_CACHE_STALE_MS=604800000
WIKIPEDIA_ATTRIBUTION_CACHE_MS=604800000
WIKIPEDIA_ATTRIBUTION_NEGATIVE_CACHE_MS=21600000
WIKIPEDIA_RATE_LIMIT=240

WIKIPEDIA_DATABASE_URL=
WIKIPEDIA_DB_HOST=localhost
WIKIPEDIA_DB_PORT=5432
WIKIPEDIA_DB_NAME=messagedrop_wikipedia
WIKIPEDIA_DB_USER=messagedrop
WIKIPEDIA_DB_PASSWORD=messagedrop_dev_password
WIKIPEDIA_DB_SSL=false
WIKIPEDIA_DB_POOL_MAX=10
WIKIPEDIA_DB_MAX_PENDING_REQUESTS=1000
WIKIPEDIA_DB_OVERLOAD_RETRY_AFTER_SECONDS=2

SERVICE_JWT_AUDIENCE=service.wikipedia
WIKIPEDIA_SERVICE_JWT_ISSUER=service.wikipedia
SERVICE_JWT_AUDIENCE_ADMIN=service.admin-backend
SERVICE_JWT_TRUSTED_JWKS_PATH=./config/service-jwks.json
ADMIN_BASE_URL=http://localhost
ADMIN_PORT=3100
TRUST_PROXY=loopback, linklocal, uniquelocal
LOG_RETENTION_INFO=2d
