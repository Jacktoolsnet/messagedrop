# Viator service
NODE_ENV=development
EXIT_ON_UNHANDLED=false
STARTUP_DEBUG=false
# Preferred explicit service port (fallback order in code: VIATOR_PORT -> PORT -> 3500)
VIATOR_PORT=3500
TZ=Europe/Berlin

# Admin log forwarding
ADMIN_BASE_URL=http://localhost
ADMIN_PORT=3100
ADMIN_LOG_URL=
SERVICE_JWT_AUDIENCE_ADMIN=service.admin-backend

# Service JWT
SERVICE_JWT_ISSUER=service.viator
SERVICE_JWT_AUDIENCE=service.viator
SERVICE_JWT_TRUSTED_JWKS=
SERVICE_JWT_TRUSTED_JWKS_PATH=

# Encryption keys
ENCRYPTION_KEY_PASSWORD=change_me
SIGNING_KEY_PASSWORD=change_me

# Viator upstream API
VIATOR_API_BASE_URL=https://api.sandbox.viator.com/partner
VIATOR_API_KEY=change_me
VIATOR_API_TIMEOUT_MS=15000
VIATOR_ACCEPT_LANGUAGE=en
VIATOR_LOG_UPSTREAM_STATUS=false
VIATOR_LOG_UPSTREAM_REQUEST_BODY=false

# Logging
LOG_RETENTION_INFO=2d
LOG_RETENTION_ERROR=2d

# PostgreSQL database (Viator service)
# Prefer VIATOR_DATABASE_URL when available. Otherwise VIATOR_DB_* is used.
VIATOR_DATABASE_URL=
VIATOR_DB_HOST=localhost
VIATOR_DB_PORT=5432
VIATOR_DB_NAME=messagedrop_viator
VIATOR_DB_USER=messagedrop
VIATOR_DB_PASSWORD=messagedrop_dev_password
VIATOR_DB_SSL=false
VIATOR_DB_POOL_MAX=10
