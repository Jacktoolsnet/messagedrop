{
  "name": "Messagedrop Admin",
  "version": "1.0.0",
  "scripts": {
    "gen:version": "node tools/gen-version.js",
    "ng": "ng",
    "prestart": "npm run gen:version",
    "start": "ng serve",
    "prebuild": "npm run gen:version",
    "build": "ng build",
    "install:prod": "npm install --omit=dev",
    "prewatch": "npm run gen:version",
    "watch": "ng build --watch --configuration development",
    "pretest": "npm run gen:version",
    "test": "ng test",
    "lint": "ng lint",
    "build:pstage": "npm run gen:version && ng build --configuration production",
    "build:qstage": "npm run gen:version && ng build --configuration qstage"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "22.0.2",
    "@angular/common": "22.0.2",
    "@angular/compiler": "22.0.2",
    "@angular/core": "22.0.2",
    "@angular/forms": "22.0.2",
    "@angular/material": "22.0.2",
    "@angular/platform-browser": "22.0.2",
    "@angular/router": "22.0.2",
    "@angular/service-worker": "22.0.2",
    "chart.js": "^4.5.0",
    "chartjs-plugin-annotation": "^3.1.0",
    "leaflet": "^1.9.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.3",
    "@angular/cli": "22.0.3",
    "@angular/compiler-cli": "22.0.2",
    "@types/jasmine": "~5.1.0",
    "@types/leaflet": "^1.9.20",
    "angular-eslint": "^22.0.0",
    "baseline-browser-mapping": "^2.9.5",
    "eslint": "^10.5.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "undici": "7.24.0"
  }
}
