# Sticker service
NODE_ENV=development
EXIT_ON_UNHANDLED=false
STARTUP_DEBUG=false
# Preferred explicit service port (fallback order in code: STICKER_PORT -> PORT -> 3600)
STICKER_PORT=3600
# JSON body limit for admin/proxy sticker imports. Accepts Express size strings, e.g. 10mb.
STICKER_JSON_BODY_LIMIT=10mb

# Admin log forwarding
ADMIN_BASE_URL=http://localhost
ADMIN_PORT=3100
ADMIN_LOG_URL=
SERVICE_JWT_AUDIENCE_ADMIN=service.admin-backend

# Service JWT
SERVICE_JWT_ISSUER=service.sticker
SERVICE_JWT_AUDIENCE=service.sticker
SERVICE_JWT_TRUSTED_JWKS=
SERVICE_JWT_TRUSTED_JWKS_PATH=

# Encryption keys
ENCRYPTION_KEY_PASSWORD=change_me
SIGNING_KEY_PASSWORD=change_me

# Flaticon upstream API
FLATICON_API_KEY=change_me
FLATICON_HTTP_TIMEOUT_MS=12000

# Logging
LOG_RETENTION_INFO=2d
LOG_RETENTION_WARN=2d
LOG_RETENTION_ERROR=2d

# PostgreSQL database (Sticker service)
# Prefer STICKER_DATABASE_URL when available. Otherwise STICKER_DB_* is used.
STICKER_DATABASE_URL=
STICKER_DB_HOST=localhost
STICKER_DB_PORT=5432
STICKER_DB_NAME=messagedrop_sticker
STICKER_DB_USER=messagedrop
STICKER_DB_PASSWORD=messagedrop_dev_password
STICKER_DB_SSL=false
# Sticker PostgreSQL backpressure: STICKER_DB_POOL_MAX controls parallel DB connections.
# STICKER_DB_MAX_PENDING_REQUESTS limits total active/waiting Sticker DB tasks before returning 503 database_busy.
STICKER_DB_POOL_MAX=10
STICKER_DB_MAX_PENDING_REQUESTS=1000
STICKER_DB_OVERLOAD_RETRY_AFTER_SECONDS=2
